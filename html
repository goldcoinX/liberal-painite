<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Liberal Painite | Premium Destinations</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .whitespace-generous { padding: 4rem 0; }
        .accent-yellow { color: #FFD700; }
        .bg-accent { background-color: #FFD700; }
    </style>
</head>
<body class="bg-white text-black font-sans antialiased">

    <!-- Navigation -->
    <nav class="flex justify-between items-center py-6 px-10">
        <div class="text-2xl font-bold tracking-tighter">LIBERAL PAINITE</div>
        <a href="#inquiry" class="bg-black text-white px-6 py-2 rounded-full hover:bg-zinc-800 transition">Inquire</a>
    </nav>

    <!-- Hero Section -->
    <header class="h-screen flex flex-col justify-center items-center text-center px-6">
        <h1 class="text-6xl md:text-8xl font-medium tracking-tight mb-6">Rare Destinations.</h1>
        <p class="text-xl text-zinc-500 max-w-2xl mb-10">Curated experiences for the discerning traveler. Uncompromising quality, absolute discretion.</p>
        <div class="bg-accent text-black font-bold py-4 px-12 rounded-full cursor-pointer hover:opacity-90 transition">Explore Collection</div>
    </header>

    <!-- Inquiry Form -->
    <section id="inquiry" class="whitespace-generous px-10 max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold mb-10">Begin Your Journey</h2>
        <form class="grid grid-cols-1 gap-6">
            <input type="text" placeholder="Name" class="w-full border-b-2 border-black py-4 outline-none">
            <input type="email" placeholder="Email" class="w-full border-b-2 border-black py-4 outline-none">
            <textarea placeholder="Tell us about your ideal escape" class="w-full border-b-2 border-black py-4 outline-none"></textarea>
            <button class="bg-black text-white py-4 w-full uppercase tracking-widest hover:bg-zinc-800">Submit Inquiry</button>
        </form>
    </section>

    <!-- WhatsApp Floating Button -->
    <a href="https://wa.me/YOUR_NUMBER" class="fixed bottom-10 right-10 bg-green-500 text-white p-4 rounded-full shadow-lg hover:scale-110 transition">
        Chat Now
    </a>

</body>
</html>
